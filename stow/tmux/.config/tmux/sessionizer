#!/usr/bin/env bash

PATH=$PATH:/opt/homebrew/bin

trap 'exit 0' INT

if [[ $# -eq 1 ]]; then
  selected=$1
else
  if tmux_sessions=$(tmux list-sessions -F '#S' 2>/dev/null); then
    header_text="$tmux_sessions"
  else
    header_text=""
  fi

  selected=$(find ~ ~/work ~/playground -mindepth 0 -maxdepth 2 -type d | sort | uniq | fzf \
    --height=80% \
    --layout=reverse \
    --border \
    --margin=10%,20% \
    --no-info \
    --header="$header_text") || exit 0
fi

if [[ -z "$selected" ]]; then
  exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux 2>/dev/null)

# No tmux running and we're not inside tmux: start a fresh session
if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
  exec tmux new-session -s "$selected_name" -c "$selected" \; \
    set-option @session-root "$selected"
fi

# If the session doesn't exist yet, create it and set @session-root
if ! tmux has-session -t="$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected"
fi

# Always (re)set the session's root option to the selected dir
tmux set-option -t "$selected_name" @session-root "$selected"

tmux switch-client -t "$selected_name" 2>/dev/null || tmux attach -t "$selected_name"
