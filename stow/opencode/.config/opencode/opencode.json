{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    }
  },
  "model": "cursorapi/composer-2.5-fast",
  "provider": {
    "cursorapi": {
      "models": {
        "composer-2.5": {
          "cost": {
            "input": 0.5,
            "output": 2.5
          },
          "limit": {
            "context": 200000,
            "output": 65536
          },
          "name": "Composer 2.5"
        },
        "composer-2.5-fast": {
          "cost": {
            "input": 3,
            "output": 15
          },
          "limit": {
            "context": 200000,
            "output": 65536
          },
          "name": "Composer 2.5 Fast"
        }
      },
      "name": "API for Cursor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "cursor-local",
        "baseURL": "http://127.0.0.1:8787/v1"
      }
    }
  }
}
