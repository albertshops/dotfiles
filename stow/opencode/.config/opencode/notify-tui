#!/usr/bin/env bash

set -u

PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
export PATH

TOGGLE_KEYS=(
  "NOTIFY_SOUND"
  "NOTIFY_DESKTOP"
  "NOTIFY_TELEGRAM"
)

TOGGLE_LABELS=(
  "sound"
  "desktop"
  "telegram"
)

toggle_values=(0 0 0)
desired_values=(0 0 0)
env_lines=()

exit_with_error() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

print_help() {
  cat <<'EOF'
Usage: notify-tui [--env <path>]

Minimal TUI for toggling notification flags in .env:
  - NOTIFY_DESKTOP
  - NOTIFY_SOUND
  - NOTIFY_TELEGRAM

Keys:
  j/k: move
  Space: toggle selected item
  Enter: save
  Esc/q: quit without saving
EOF
}

resolve_path() {
  case "$1" in
    /*) printf '%s\n' "$1" ;;
    *) printf '%s/%s\n' "$PWD" "$1" ;;
  esac
}

index_for_key() {
  local query="$1"
  local i
  for ((i = 0; i < ${#TOGGLE_KEYS[@]}; i += 1)); do
    if [[ "${TOGGLE_KEYS[$i]}" == "$query" ]]; then
      printf '%s' "$i"
      return 0
    fi
  done
  return 1
}

index_for_label() {
  local query="$1"
  local i
  for ((i = 0; i < ${#TOGGLE_LABELS[@]}; i += 1)); do
    if [[ "${TOGGLE_LABELS[$i]}" == "$query" ]]; then
      printf '%s' "$i"
      return 0
    fi
  done
  return 1
}

parse_args() {
  local user_home="${HOME:-}"
  if [[ -z "$user_home" ]]; then
    exit_with_error "HOME is not set; pass --env <path>"
  fi

  env_path="$user_home/.config/opencode/.env"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        print_help
        exit 0
        ;;
      --env)
        if [[ $# -lt 2 ]]; then
          exit_with_error "Missing value for --env"
        fi
        env_path="$2"
        shift 2
        ;;
      --env=*)
        env_path="${1#--env=}"
        shift
        ;;
      *)
        exit_with_error "Unknown argument: $1"
        ;;
    esac
  done

  env_path="$(resolve_path "$env_path")"
}

read_env_file() {
  [[ -f "$env_path" ]] || exit_with_error "Unable to read $env_path: file does not exist"

  env_lines=()
  local line
  line=""
  while IFS= read -r line || [[ -n "$line" ]]; do
    env_lines+=("$line")
  done < "$env_path"

  local i
  for ((i = 0; i < ${#TOGGLE_KEYS[@]}; i += 1)); do
    toggle_values[$i]=0
  done

  local key value idx
  for line in "${env_lines[@]}"; do
    if [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
      key="${BASH_REMATCH[1]}"
      value="${BASH_REMATCH[2]}"
      if idx="$(index_for_key "$key")"; then
        if [[ "${value//[[:space:]]/}" == "1" ]]; then
          toggle_values[$idx]=1
        fi
      fi
    fi
  done
}

build_start_bind() {
  local bind_sequence=""
  local current_index=1
  local i key

  for i in "${!TOGGLE_KEYS[@]}"; do
    if [[ "${toggle_values[$i]}" != "1" ]]; then
      continue
    fi

    local target_index=$((i + 1))
    while [[ $current_index -lt $target_index ]]; do
      if [[ -n "$bind_sequence" ]]; then
        bind_sequence+="+"
      fi
      bind_sequence+="down"
      current_index=$((current_index + 1))
    done

    if [[ -n "$bind_sequence" ]]; then
      bind_sequence+="+"
    fi
    bind_sequence+="toggle"
  done

  while [[ $current_index -gt 1 ]]; do
    if [[ -n "$bind_sequence" ]]; then
      bind_sequence+="+"
    fi
    bind_sequence+="up"
    current_index=$((current_index - 1))
  done

  if [[ -n "$bind_sequence" ]]; then
    start_bind="start:$bind_sequence"
  else
    start_bind=""
  fi
}

run_picker() {
  [[ -t 0 && -t 1 ]] || exit_with_error "This command requires an interactive terminal (TTY)."

  command -v fzf >/dev/null 2>&1 || exit_with_error "fzf is required but was not found in PATH"

  build_start_bind

  local bind_arg="q:abort"
  if [[ -n "$start_bind" ]]; then
    bind_arg+=",$start_bind"
  fi

  selected_labels="$(printf '%s\n' "${TOGGLE_LABELS[@]}" | fzf \
    --multi \
    --height=80% \
    --layout=reverse \
    --border \
    --margin=10%,20% \
    --no-info \
    --header="notify-tui ($env_path)" \
    --prompt="notify> " \
    --bind "$bind_arg")" || exit 0
}

set_desired_values() {
  local i

  for ((i = 0; i < ${#TOGGLE_KEYS[@]}; i += 1)); do
    desired_values[$i]=0
  done

  local label idx
  while IFS= read -r label; do
    [[ -n "$label" ]] || continue
    if idx="$(index_for_label "$label")"; then
      desired_values[$idx]=1
    fi
  done <<< "$selected_labels"
}

write_env_file() {
  local updated_lines=()
  local seen=(0 0 0)
  local line key matched idx i

  for line in "${env_lines[@]}"; do
    matched=0
    if [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
      key="${BASH_REMATCH[1]}"
      if idx="$(index_for_key "$key")"; then
        updated_lines+=("$key=${desired_values[$idx]}")
        seen[$idx]=1
        matched=1
      fi
    fi

    if [[ $matched -eq 0 ]]; then
      updated_lines+=("$line")
    fi
  done

  for ((i = 0; i < ${#TOGGLE_KEYS[@]}; i += 1)); do
    if [[ "${seen[$i]}" -eq 0 ]]; then
      updated_lines+=("${TOGGLE_KEYS[$i]}=${desired_values[$i]}")
    fi
  done

  local tmp_file
  tmp_file="$(mktemp "${TMPDIR:-/tmp}/notify-tui.XXXXXX")"
  trap 'rm -f "$tmp_file"' EXIT

  printf '%s\n' "${updated_lines[@]}" > "$tmp_file"
  mv "$tmp_file" "$env_path"
  trap - EXIT
}

main() {
  parse_args "$@"
  read_env_file
  run_picker
  set_desired_values
  write_env_file
  printf 'Saved.\n'
}

main "$@"
